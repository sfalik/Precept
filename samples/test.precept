precept Document

field Title as string nullable
field Author as string nullable
field Content as string nullable
field Approvers as set of string

state Draft initial
state ReadyForReview
in ReadyForReview assert Approvers.count > 0 because "Must have pending approvers while in review"
state Published
in Published assert Approvers.count == 0 because "All approvers must have approved"

event AddApprover with ApproverName as string
on AddApprover assert ApproverName != "" because "Approver name is required"

event RemoveApprover with ApproverName as string

event SendForReview
event Approve with ApproverName as string
on Approve assert ApproverName != "" because "Approver name is required"

from Draft on AddApprover -> add Approvers AddApprover.ApproverName -> no transition

from Draft on RemoveApprover when Approvers contains RemoveApprover.ApproverName -> remove Approvers RemoveApprover.ApproverName -> no transition
from Draft on RemoveApprover -> reject "Approver is not on the list"

from Draft on SendForReview when Approvers.count > 0 -> transition ReadyForReview
from Draft on SendForReview -> reject "At least one approver must be added before sending for review"

from ReadyForReview on Approve when Approvers contains Approve.ApproverName && Approvers.count == 1 -> remove Approvers Approve.ApproverName -> transition Published
from ReadyForReview on Approve when Approvers contains Approve.ApproverName -> remove Approvers Approve.ApproverName -> no transition
from ReadyForReview on Approve -> reject "Approver is not on the pending list"