precept Document

field Author as string nullable
field Age as number default 12
field Text as string default ""
field Reviewer as string nullable
field Approver as string nullable

state Draft initial
state Reviewed
state Approved

event SendForReview with Reviewer as string, age as number nullable
event Redraft
event Approve with Approver as string

in Draft edit Text, Author, Age
invariant Age >= 12 because "Author must be at least 12 years old"
on SendForReview assert Reviewer != "" because "Reviewer must be specified" 

from Draft on SendForReview -> set Reviewer = SendForReview.Reviewer -> transition Reviewed

from Reviewed on Redraft -> set Reviewer = null -> transition Draft

from Reviewed on Approve -> set Approver = Approve.Approver -> transition Approved