precept BankAccount

field Balance as number default 500
invariant Balance >= -500 because "Balance may not exceed overdraft limit of $500"

# States
state Active initial
state Overdrawn
state Suspended

# Events
event Deposit with Amount as number
on Deposit assert Amount > 0 because "Deposit amount must be positive"

event Withdraw with Amount as number
on Withdraw assert Amount > 0 because "Withdrawal amount must be positive"

event Suspend
event Resume

# Transitions

from Active on Deposit -> set Balance = Balance + Deposit.Amount -> no transition

# Withdraw is only applicable when there is a positive balance to draw from;
# Balance = 0 makes the event NotApplicable rather than Rejected.
from Active on Withdraw when Balance > 0 && Balance - Withdraw.Amount >= 0 -> set Balance = Balance - Withdraw.Amount -> no transition
from Active on Withdraw when Balance > 0 -> set Balance = Balance - Withdraw.Amount -> transition Overdrawn

from Overdrawn on Deposit when Balance + Deposit.Amount >= 0 -> set Balance = Balance + Deposit.Amount -> transition Active
from Overdrawn on Deposit -> set Balance = Balance + Deposit.Amount -> no transition

# Suspend / Resume
from Active, Overdrawn on Suspend -> transition Suspended

from Suspended on Resume -> transition Active

# Expected manual test outcomes
#
# Starting state: Active, Balance=500
#
# 1. Deposit { Amount: 100 }   -> AcceptedInPlace,  Balance=600, state Active
# 2. Withdraw { Amount: 200 }  -> AcceptedInPlace,  Balance=400, state Active
# 3. Withdraw { Amount: 450 }  -> Accepted (->Overdrawn), Balance=-50
# 4. Deposit { Amount: 30 }   -> AcceptedInPlace,  Balance=-20  (still Overdrawn)
# 5. Deposit { Amount: 20 }   -> Accepted (->Active), Balance=0
# 6. Withdraw { Amount: 10 }  -> NotApplicable  (Balance=0, when Balance > 0 is false)
# 7. Deposit { Amount: 100 }  -> AcceptedInPlace,  Balance=100
# 8. Withdraw { Amount: 200 } -> Rejected  (Amount > Balance, rule fires)
# 9. Suspend {}               -> Accepted (->Suspended)
# 10. Deposit { Amount: 50 }  -> NotDefined  (no transition from Suspended)
# 11. Resume {}               -> Accepted (->Active), Balance=100
