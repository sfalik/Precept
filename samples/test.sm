machine Test

string? LastAdded
string? LastRemoved
queue<string> Names

state Start initial
state End

event add
    string Name
event remove

from Start on add
 if add.Name != ""
    enqueue Names add.Name
    no transition
 else
    reject "Name cannot be empty"

from Start on remove
    if Names.count > 0
        dequeue Names into LastRemoved
        no transition
    else
        transition End