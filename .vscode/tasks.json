{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "command": "dotnet",
    "args": [],
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "_id": "build",
                "isDefault": false
            }
        },
        {
            "label": "extension: loop local install",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "loop:local"
            ],
            "options": {
                "cwd": "${workspaceFolder}/tools/StateMachine.Dsl.VsCode"
            },
            "problemMatcher": []
        }
    ]
}