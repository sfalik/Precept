{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "command": "dotnet",
    "args": [],
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/tools/Precept.LanguageServer/Precept.LanguageServer.csproj",
                "--artifacts-path",
                "${workspaceFolder}/temp/dev-language-server"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "_id": "build",
                "isDefault": true
            }
        },
        {
            "label": "extension: install",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "loop:local"
            ],
            "options": {
                "cwd": "${workspaceFolder}/tools/Precept.VsCode"
            },
            "problemMatcher": []
        },
        {
            "label": "extension: uninstall",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "loop:local:uninstall"
            ],
            "options": {
                "cwd": "${workspaceFolder}/tools/Precept.VsCode"
            },
            "problemMatcher": []
        },
        {
            "label": "plugin: sync payload",
            "type": "shell",
            "command": "node",
            "args": [
                "${workspaceFolder}/tools/scripts/sync-precept-plugin-assets.js"
            ],
            "problemMatcher": []
        }
    ]
}