# Demonstrates: C92, C93 — literal zero, exact-zero expressions, and unresolved proof variants

# This file covers all three shipped C93 message branches plus a second C92 shape.

precept DivisorSafetyDemo

field Amount as number default 100 positive
field UnknownDivisor as number default 1
field NonnegativeDivisor as number default 0 nonnegative
field BoundedOffset as number default 1 min 0 max 2
field Result as number default 0

state Active initial
state Done

event DivideByLiteralZero
event DivideByExactZeroExpression
event DivideByUnproven
event DivideByNonnegative
event DivideByRanged
event DivideSafely

# C92: literal 0 is always provably zero.
# EXPECT: C92 | severity=error | match=exact | message=Division by zero: divisor '0' is provably zero. (from: constant expression) | line=25 | start=60 | end=61
from Active on DivideByLiteralZero -> set Result = Amount / 0 -> transition Done

# C92: a normalized exact-zero expression is also provably zero.
# EXPECT: C92 | severity=error | match=exact | message=Division by zero: divisor 'expression' is provably zero. (from: constant expression) | line=29 | start=68 | end=101
from Active on DivideByExactZeroExpression -> set Result = Amount / (UnknownDivisor - UnknownDivisor) -> transition Done

# C93: UnknownDivisor has no compile-time nonzero proof at all.
# EXPECT: C93 | severity=error | match=exact | message=Divisor 'UnknownDivisor' has no compile-time nonzero proof. Consider adding a 'positive' constraint, 'rule UnknownDivisor != 0', or 'when UnknownDivisor != 0' guard. | line=33 | start=57 | end=71
from Active on DivideByUnproven -> set Result = Amount / UnknownDivisor -> transition Done

# C93: nonnegative still allows zero, so the proof obligation remains unresolved.
# EXPECT: C93 | severity=error | match=exact | message=Divisor 'NonnegativeDivisor' is nonnegative but not nonzero — 'nonnegative' allows zero. Consider 'positive' instead. (from: field constraint: nonnegative) | line=37 | start=60 | end=78
from Active on DivideByNonnegative -> set Result = Amount / NonnegativeDivisor -> transition Done

# C93: BoundedOffset - 1 produces the bounded interval [-1, 1], which still includes zero.
# EXPECT: C93 | severity=error | match=exact | message=Divisor 'expression' interval [-1, 1] may include zero. Consider restructuring with a 'positive' constraint or 'rule != 0'. | line=41 | start=55 | end=74
from Active on DivideByRanged -> set Result = Amount / (BoundedOffset - 1) -> transition Done

# SAFE: the guard proves UnknownDivisor > 0 inside this row.
from Active on DivideSafely when UnknownDivisor > 0 -> set Result = Amount / UnknownDivisor -> transition Done
from Active on DivideSafely -> transition Done
