{
  "name": "state-machine-dsl-vscode",
  "displayName": "StateMachine DSL",
  "description": "VS Code client for StateMachine .sm language server diagnostics and completion.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:**/*.sm"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "state-machine-dsl",
        "aliases": [
          "StateMachine DSL",
          "state-machine-dsl"
        ],
        "extensions": [
          ".sm"
        ],
        "scopeName": "source.state-machine-dsl",
        "semanticHighlighting": true,
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "state-machine-dsl",
        "scopeName": "source.state-machine-dsl",
        "path": "./syntaxes/state-machine-dsl.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.17.24",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.7.3",
    "vscode-languageclient": "^9.0.1"
  }
}
