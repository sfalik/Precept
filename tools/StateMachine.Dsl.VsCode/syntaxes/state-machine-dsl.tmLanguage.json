{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "StateMachine DSL",
  "scopeName": "source.state-machine-dsl",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#machineDeclaration"
    },
    {
      "include": "#stateDeclaration"
    },
    {
      "include": "#eventDeclaration"
    },
    {
      "include": "#fromOnHeader"
    },
    {
      "include": "#controlKeywords"
    },
    {
      "include": "#actionKeywords"
    },
    {
      "include": "#typeKeywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#booleanNull"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.state-machine-dsl",
          "match": "#.*$"
        }
      ]
    },
    "machineDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.machine.state-machine-dsl",
          "match": "^(\\s*)(machine)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.state-machine-dsl"
            },
            "4": {
              "name": "entity.name.type.machine.state-machine-dsl"
            }
          }
        }
      ]
    },
    "stateDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.state.state-machine-dsl",
          "match": "^(\\s*)(state)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.state-machine-dsl"
            },
            "4": {
              "name": "entity.name.type.state.state-machine-dsl"
            }
          }
        }
      ]
    },
    "eventDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.event.state-machine-dsl",
          "match": "^(\\s*)(event)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.state-machine-dsl"
            },
            "4": {
              "name": "entity.name.function.event.state-machine-dsl"
            }
          }
        }
      ]
    },
    "fromOnHeader": {
      "patterns": [
        {
          "name": "meta.transition.header.state-machine-dsl",
          "match": "^(\\s*)(from)(\\s+)(any|[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)(\\s+)(on)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.state-machine-dsl"
            },
            "4": {
              "name": "entity.name.type.state.state-machine-dsl"
            },
            "6": {
              "name": "keyword.control.state-machine-dsl"
            },
            "8": {
              "name": "entity.name.function.event.state-machine-dsl"
            }
          }
        }
      ]
    },
    "controlKeywords": {
      "patterns": [
        {
          "name": "keyword.control.state-machine-dsl",
          "match": "\\b(machine|state|event|from|on|if|else)\\b"
        }
      ]
    },
    "actionKeywords": {
      "patterns": [
        {
          "name": "keyword.other.state-machine-dsl",
          "match": "\\b(transition|reject|transform|reason|any)\\b"
        },
        {
          "name": "keyword.other.state-machine-dsl",
          "match": "\\bno\\s+transition\\b"
        }
      ]
    },
    "typeKeywords": {
      "patterns": [
        {
          "name": "storage.type.state-machine-dsl",
          "match": "\\b(string|number|boolean|null)\\??\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.state-machine-dsl",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.comparison.state-machine-dsl",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.assignment.state-machine-dsl",
          "match": "="
        }
      ]
    },
    "booleanNull": {
      "patterns": [
        {
          "name": "constant.language.state-machine-dsl",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.state-machine-dsl",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.state-machine-dsl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.state-machine-dsl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.state-machine-dsl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.state-machine-dsl",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}
