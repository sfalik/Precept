{
  "name": "precept-vscode",
  "displayName": "Precept",
  "description": "VS Code extension for Precept .precept files with language server diagnostics, completions, and live preview.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:precept",
    "workspaceContains:**/*.precept"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "precept",
        "aliases": [
          "Precept",
          "precept"
        ],
        "extensions": [
          ".precept"
        ],
        "scopeName": "source.precept",
        "semanticHighlighting": true,
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "precept",
        "scopeName": "source.precept",
        "path": "./syntaxes/precept.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "precept.openPreview",
        "title": "Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "precept.togglePreviewLocking",
        "title": "Toggle Preview Locking",
        "icon": "$(lock)"
      },
      {
        "command": "precept.showLanguageServerMode",
        "title": "Show Language Server Mode",
        "icon": "$(server-process)"
      },
      {
        "command": "precept.showFixHint",
        "title": "Precept: Show Fix Hint"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "precept.openPreview",
          "when": "resourceExtname == .precept",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "precept.openPreview",
          "when": "editorLangId == precept"
        },
        {
          "command": "precept.togglePreviewLocking"
        },
        {
          "command": "precept.showLanguageServerMode"
        }
      ]
    },
    "keybindings": [
      {
        "command": "precept.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == precept"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "preceptName",
        "description": "Precept declaration name"
      },
      {
        "id": "preceptKeywordSemantic",
        "description": "Precept behavioral structure keyword"
      },
      {
        "id": "preceptKeywordGrammar",
        "description": "Precept grammar connective keyword"
      },
      {
        "id": "preceptOperator",
        "description": "Precept operator"
      },
      {
        "id": "preceptState",
        "description": "Precept state name"
      },
      {
        "id": "preceptEvent",
        "description": "Precept event name"
      },
      {
        "id": "preceptType",
        "description": "Precept type keyword"
      },
      {
        "id": "preceptValue",
        "description": "Precept literal value"
      },
      {
        "id": "preceptFieldName",
        "description": "Precept field name"
      },
      {
        "id": "preceptArgName",
        "description": "Precept argument name"
      },
      {
        "id": "preceptMessage",
        "description": "Precept message string"
      },
      {
        "id": "preceptComment",
        "description": "Precept comment"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "preceptConstrained",
        "description": "Token is under active constraint pressure"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "precept",
        "scopes": {
          "preceptName": [
            "entity.name.precept"
          ],
          "preceptKeywordSemantic": [
            "keyword.other.semantic.precept"
          ],
          "preceptKeywordGrammar": [
            "keyword.other.grammar.precept"
          ],
          "preceptOperator": [
            "keyword.operator.precept"
          ],
          "preceptState": [
            "entity.name.state.precept"
          ],
          "preceptState.preceptConstrained": [
            "entity.name.state.constrained.precept"
          ],
          "preceptEvent": [
            "entity.name.event.precept"
          ],
          "preceptEvent.preceptConstrained": [
            "entity.name.function.event.constrained.precept"
          ],
          "preceptFieldName": [
            "variable.other.field.precept"
          ],
          "preceptFieldName.preceptConstrained": [
            "variable.other.field.constrained.precept"
          ],
          "preceptArgName": [
            "variable.parameter.arg.precept"
          ],
          "preceptArgName.preceptConstrained": [
            "variable.parameter.arg.constrained.precept"
          ],
          "preceptType": [
            "entity.name.type.precept"
          ],
          "preceptValue": [
            "constant.language.precept"
          ],
          "preceptMessage": [
            "string.other.message.precept"
          ],
          "preceptComment": [
            "comment.line.precept"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[precept]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.wordBasedSuggestions": "off"
      },
      "editor.tokenColorCustomizations": {
        "[*]": {
          "textMateRules": [
            {
              "scope": "keyword.other.semantic.precept",
              "settings": {
                "foreground": "#4338CA",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "keyword.other.constraint.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.other.connective.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.control.precept",
              "settings": {
                "foreground": "#4338CA"
              }
            },
            {
              "scope": "keyword.other.precept",
              "settings": {
                "foreground": "#4338CA"
              }
            },
            {
              "scope": "entity.name.type.state.precept",
              "settings": {
                "foreground": "#A898F5"
              }
            },
            {
              "scope": "entity.name.type.state.constrained.precept",
              "settings": {
                "foreground": "#A898F5",
                "fontStyle": "italic"
              }
            },
            {
              "scope": "entity.name.function.event.precept",
              "settings": {
                "foreground": "#30B8E8"
              }
            },
            {
              "scope": "entity.name.function.event.constrained.precept",
              "settings": {
                "foreground": "#30B8E8",
                "fontStyle": "italic"
              }
            },
            {
              "scope": "variable.other.field.precept",
              "settings": {
                "foreground": "#A5B4FC"
              }
            },
            {
              "scope": "variable.other.field.constrained.precept",
              "settings": {
                "foreground": "#A5B4FC",
                "fontStyle": "italic"
              }
            },
            {
              "scope": "variable.other.property.precept",
              "settings": {
                "foreground": "#A5B4FC"
              }
            },
            {
              "scope": "variable.other.precept",
              "settings": {
                "foreground": "#A5B4FC"
              }
            },
            {
              "scope": "variable.parameter.precept",
              "settings": {
                "foreground": "#9AD8E8"
              }
            },
            {
              "scope": "variable.parameter.property.precept",
              "settings": {
                "foreground": "#9AD8E8"
              }
            },
            {
              "scope": "entity.name.type.precept.precept",
              "settings": {
                "foreground": "#A5B4FC"
              }
            },
            {
              "scope": "storage.type.precept",
              "settings": {
                "foreground": "#9AA8B5"
              }
            },
            {
              "scope": "constant.other.value.precept",
              "settings": {
                "foreground": "#84929F"
              }
            },
            {
              "scope": "constant.language.precept",
              "settings": {
                "foreground": "#84929F"
              }
            },
            {
              "scope": "constant.numeric.precept",
              "settings": {
                "foreground": "#84929F"
              }
            },
            {
              "scope": "string.quoted.double.precept",
              "settings": {
                "foreground": "#84929F"
              }
            },
            {
              "scope": "string.quoted.double.message.precept",
              "settings": {
                "foreground": "#FBBF24"
              }
            },
            {
              "scope": "keyword.operator.comparison.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.operator.logical.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.operator.arithmetic.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.operator.assignment.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "punctuation.separator.arrow.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "punctuation.separator.comma.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "punctuation.accessor.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "punctuation.section.group.begin.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "punctuation.section.group.end.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "comment.line.number-sign.precept",
              "settings": {
                "foreground": "#9096A6",
                "fontStyle": "italic"
              }
            },
            {
              "scope": "keyword.declaration.precept",
              "settings": {
                "foreground": "#4338CA"
              }
            },
            {
              "scope": "keyword.other.grammar.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.other.action.precept",
              "settings": {
                "foreground": "#4338CA",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "keyword.other.assertion.precept",
              "settings": {
                "foreground": "#4338CA",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "keyword.other.outcome.precept",
              "settings": {
                "foreground": "#4338CA",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "keyword.other.access-mode.precept",
              "settings": {
                "foreground": "#4338CA",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "keyword.other.quantifier.precept",
              "settings": {
                "foreground": "#4338CA"
              }
            },
            {
              "scope": "storage.modifier.state.precept",
              "settings": {
                "foreground": "#9AA8B5"
              }
            },
            {
              "scope": "constant.language.boolean.precept",
              "settings": {
                "foreground": "#84929F"
              }
            },
            {
              "scope": "string.quoted.single.precept",
              "settings": {
                "foreground": "#84929F"
              }
            },
            {
              "scope": "keyword.operator.arrow.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.operator.membership.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "keyword.operator.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            },
            {
              "scope": "punctuation.precept",
              "settings": {
                "foreground": "#6366F1"
              }
            }
          ]
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev:watch": "tsc -watch -p ./ --preserveWatchOutput",
    "bundle": "npm run compile && node ./esbuild.js",
    "package:local": "npx @vscode/vsce package --allow-missing-repository",
    "package:marketplace": "npx @vscode/vsce package --allow-missing-repository",
    "loop:local": "powershell -ExecutionPolicy Bypass -File ./scripts/install-local.ps1",
    "loop:local:uninstall": "powershell -ExecutionPolicy Bypass -File ./scripts/uninstall-local.ps1",
    "vscode:prepublish": "npm run bundle && dotnet publish ../../tools/Precept.LanguageServer/Precept.LanguageServer.csproj -c Release -o ./server --no-self-contained"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.24",
    "@types/vscode": "^1.109.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
