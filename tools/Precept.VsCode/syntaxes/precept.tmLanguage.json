{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Precept",
  "scopeName": "source.precept",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#machineDeclaration"
    },
    {
      "include": "#stateDeclaration"
    },
    {
      "include": "#eventDeclaration"
    },
    {
      "include": "#fromOnHeader"
    },
    {
      "include": "#simpleTransition"
    },
    {
      "include": "#eventArgReference"
    },
    {
      "include": "#fieldDeclaration"
    },
    {
      "include": "#controlKeywords"
    },
    {
      "include": "#typeKeywords"
    },
    {
      "include": "#actionKeywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#booleanNull"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#identifierReference"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.precept",
          "match": "#.*$"
        }
      ]
    },
    "machineDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.precept.precept-dsl",
          "match": "^(\\s*)(precept)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.precept"
            },
            "4": {
              "name": "entity.name.type.precept.precept-dsl"
            }
          }
        }
      ]
    },
    "stateDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.state.precept",
          "match": "^(\\s*)(state)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.precept"
            },
            "4": {
              "name": "entity.name.type.state.precept"
            }
          }
        }
      ]
    },
    "eventDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.event.precept",
          "match": "^(\\s*)(event)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.precept"
            },
            "4": {
              "name": "entity.name.function.event.precept"
            }
          }
        }
      ]
    },
    "fromOnHeader": {
      "patterns": [
        {
          "name": "meta.transition.header.precept",
          "match": "^(\\s*)(from)(\\s+)(any|[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)(\\s+)(on)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.control.precept"
            },
            "4": {
              "name": "entity.name.type.state.precept"
            },
            "6": {
              "name": "keyword.control.precept"
            },
            "8": {
              "name": "entity.name.function.event.precept"
            }
          }
        }
      ]
    },
    "controlKeywords": {
      "patterns": [
        {
          "name": "keyword.control.precept",
          "match": "\\b(machine|state|event|from|on|if|else|initial|when)\\b"
        }
      ]
    },
    "actionKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\b(transition|reject|set|reason|any|rule|add|remove|enqueue|dequeue|push|pop|clear|into|contains|above|below)\\b"
        },
        {
          "name": "keyword.other.precept",
          "match": "\\bno\\s+transition\\b"
        }
      ]
    },
    "typeKeywords": {
      "patterns": [
        {
          "name": "storage.type.precept",
          "match": "\\b(set|queue|stack)<(string|number|boolean)>\\b"
        },
        {
          "name": "storage.type.precept",
          "match": "\\b(string|number|boolean)\\??\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.precept",
          "match": "==|!=|>=|<="
        },
        {
          "name": "keyword.operator.logical.precept",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.precept",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.precept",
          "match": ">|<"
        },
        {
          "name": "keyword.operator.assignment.precept",
          "match": "="
        }
      ]
    },
    "booleanNull": {
      "patterns": [
        {
          "name": "constant.language.precept",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.precept",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "fieldDeclaration": {
      "patterns": [
        {
          "comment": "collection field: set<number> FieldName",
          "name": "meta.field-declaration.collection.precept",
          "match": "\\b(set|queue|stack)<(string|number|boolean)>\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.precept" },
            "2": { "name": "storage.type.precept" },
            "3": { "name": "variable.other.field.precept" }
          }
        },
        {
          "comment": "scalar field: number balance = 0  or  string? Name",
          "name": "meta.field-declaration.scalar.precept",
          "match": "\\b(string|number|boolean|null)(\\?)?\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.precept" },
            "2": { "name": "keyword.operator.precept" },
            "3": { "name": "variable.other.field.precept" }
          }
        }
      ]
    },
    "eventArgReference": {
      "patterns": [
        {
          "name": "meta.event-arg-ref.precept",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.event.precept"
            },
            "2": {
              "name": "punctuation.accessor.precept"
            },
            "3": {
              "name": "variable.other.property.precept"
            }
          }
        }
      ]
    },
    "simpleTransition": {
      "patterns": [
        {
          "name": "meta.transition.simple.precept",
          "match": "^(\\s*)(transition)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.other.precept"
            },
            "4": {
              "name": "entity.name.type.state.precept"
            }
          }
        }
      ]
    },
    "identifierReference": {
      "patterns": [
        {
          "comment": "catch-all for bare identifier references (field names, arg names) in expression positions",
          "name": "variable.other.precept",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.precept",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.precept",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.precept",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.precept",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}
