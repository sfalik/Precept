{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Precept",
  "scopeName": "source.precept",
  "patterns": [
    { "include": "#comment" },
    { "include": "#strings" },
    { "include": "#machineDeclaration" },
    { "include": "#stateDeclaration" },
    { "include": "#eventWithArgsDeclaration" },
    { "include": "#eventDeclaration" },
    { "include": "#fieldCollectionDeclaration" },
    { "include": "#fieldScalarDeclaration" },
    { "include": "#legacyCollectionFieldDeclaration" },
    { "include": "#legacyScalarFieldDeclaration" },
    { "include": "#invariantStatement" },
    { "include": "#assertStatement" },
    { "include": "#fromOnHeader" },
    { "include": "#transitionTarget" },
    { "include": "#eventArgReference" },
    { "include": "#collectionMemberAccess" },
    { "include": "#controlKeywords" },
    { "include": "#declarationKeywords" },
    { "include": "#typeKeywords" },
    { "include": "#actionKeywords" },
    { "include": "#outcomeKeywords" },
    { "include": "#arrowOperator" },
    { "include": "#operators" },
    { "include": "#booleanNull" },
    { "include": "#numbers" },
    { "include": "#identifierReference" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.precept",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.precept",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.precept",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "machineDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.precept.precept",
          "match": "^(\\s*)(precept)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": { "name": "entity.name.type.precept" }
          }
        }
      ]
    },
    "stateDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.state.precept",
          "match": "^(\\s*)(state)(\\s+)(.*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": {
              "patterns": [
                {
                  "name": "keyword.control.precept",
                  "match": "\\binitial\\b"
                },
                {
                  "name": "entity.name.type.state.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            }
          }
        }
      ]
    },
    "eventWithArgsDeclaration": {
      "comment": "event Name[, Name, ...] with Arg as type, Arg2 as type",
      "patterns": [
        {
          "name": "meta.declaration.event.precept",
          "match": "^(\\s*)(event)(\\s+)((?:[A-Za-z_][A-Za-z0-9_]*\\s*,\\s*)*[A-Za-z_][A-Za-z0-9_]*)(\\s+)(with)(\\s+)(.*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": {
              "patterns": [
                {
                  "name": "entity.name.function.event.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            },
            "6": { "name": "keyword.other.precept" },
            "8": {
              "patterns": [
                { "include": "#typeKeywords" },
                { "include": "#declarationKeywords" },
                { "include": "#numbers" },
                { "include": "#booleanNull" },
                { "include": "#operators" },
                {
                  "comment": "argument name before 'as'",
                  "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s+as\\b)",
                  "captures": {
                    "1": { "name": "variable.parameter.precept" }
                  }
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            }
          }
        }
      ]
    },
    "eventDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.event.precept",
          "match": "^(\\s*)(event)(\\s+)(.*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": {
              "patterns": [
                {
                  "name": "entity.name.function.event.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            }
          }
        }
      ]
    },
    "fieldCollectionDeclaration": {
      "comment": "field Name as set of string",
      "patterns": [
        {
          "name": "meta.field-declaration.collection.precept",
          "match": "^(\\s*)(field)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s+)(as)(\\s+)(set|queue|stack)(\\s+)(of)(\\s+)(string|number|boolean)",
          "captures": {
            "2": { "name": "keyword.other.precept" },
            "4": { "name": "variable.other.field.precept" },
            "6": { "name": "keyword.other.precept" },
            "8": { "name": "storage.type.precept" },
            "10": { "name": "keyword.control.precept" },
            "12": { "name": "storage.type.precept" }
          }
        }
      ]
    },
    "fieldScalarDeclaration": {
      "comment": "field Name as string nullable default value",
      "patterns": [
        {
          "name": "meta.field-declaration.scalar.precept",
          "match": "^(\\s*)(field)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s+)(as)(\\s+)(string|number|boolean)(.*)",
          "captures": {
            "2": { "name": "keyword.other.precept" },
            "4": { "name": "variable.other.field.precept" },
            "6": { "name": "keyword.other.precept" },
            "8": { "name": "storage.type.precept" },
            "9": {
              "patterns": [
                { "include": "#declarationKeywords" },
                { "include": "#booleanNull" },
                { "include": "#numbers" },
                { "include": "#strings" }
              ]
            }
          }
        }
      ]
    },
    "legacyCollectionFieldDeclaration": {
      "comment": "Legacy: set<number> FieldName",
      "patterns": [
        {
          "name": "meta.field-declaration.collection.precept",
          "match": "\\b(set|queue|stack)<(string|number|boolean)>\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.precept" },
            "2": { "name": "storage.type.precept" },
            "3": { "name": "variable.other.field.precept" }
          }
        }
      ]
    },
    "legacyScalarFieldDeclaration": {
      "comment": "Legacy: string? Name or number Balance = 0",
      "patterns": [
        {
          "name": "meta.field-declaration.scalar.precept",
          "match": "\\b(string|number|boolean|null)(\\?)?\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.precept" },
            "2": { "name": "keyword.operator.precept" },
            "3": { "name": "variable.other.field.precept" }
          }
        }
      ]
    },
    "invariantStatement": {
      "comment": "invariant Expr because \"Reason\"",
      "patterns": [
        {
          "name": "meta.invariant.precept",
          "match": "^(\\s*)(invariant)\\b",
          "captures": {
            "2": { "name": "keyword.other.precept" }
          }
        }
      ]
    },
    "assertStatement": {
      "comment": "on EventName assert Expr because \"Reason\"",
      "patterns": [
        {
          "name": "meta.assert.precept",
          "match": "^(\\s*)(on)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s+)(assert)\\b",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": { "name": "entity.name.function.event.precept" },
            "6": { "name": "keyword.other.precept" }
          }
        }
      ]
    },
    "fromOnHeader": {
      "patterns": [
        {
          "name": "meta.transition.header.precept",
          "match": "^(\\s*)(from)(\\s+)(any|[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)(\\s+)(on)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": { "name": "entity.name.type.state.precept" },
            "6": { "name": "keyword.control.precept" },
            "8": { "name": "entity.name.function.event.precept" }
          }
        }
      ]
    },
    "transitionTarget": {
      "comment": "transition StateName — highlights the state name after transition keyword",
      "patterns": [
        {
          "name": "meta.transition.target.precept",
          "match": "\\b(transition)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.precept" },
            "3": { "name": "entity.name.type.state.precept" }
          }
        }
      ]
    },
    "eventArgReference": {
      "patterns": [
        {
          "name": "meta.event-arg-ref.precept",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.event.precept" },
            "2": { "name": "punctuation.accessor.precept" },
            "3": { "name": "variable.other.property.precept" }
          }
        }
      ]
    },
    "collectionMemberAccess": {
      "comment": "Collection.count, Collection.min, etc.",
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)(count|min|max|peek)\\b",
          "captures": {
            "1": { "name": "variable.other.field.precept" },
            "2": { "name": "punctuation.accessor.precept" },
            "3": { "name": "variable.other.property.precept" }
          }
        }
      ]
    },

    "controlKeywords": {
      "patterns": [
        {
          "name": "keyword.control.precept",
          "match": "\\b(precept|state|event|from|on|if|else|initial|when|in|to|any|of)\\b"
        }
      ]
    },
    "declarationKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\b(field|as|with|assert|because|nullable|default|invariant|edit|rule)\\b"
        }
      ]
    },
    "typeKeywords": {
      "patterns": [
        {
          "name": "storage.type.precept",
          "match": "\\b(string|number|boolean|set|queue|stack)\\b"
        }
      ]
    },
    "actionKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\b(set|add|remove|enqueue|dequeue|push|pop|clear|into|contains)\\b"
        }
      ]
    },
    "outcomeKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\bno\\s+transition\\b"
        },
        {
          "name": "keyword.other.precept",
          "match": "\\b(transition|reject)\\b"
        }
      ]
    },
    "arrowOperator": {
      "patterns": [
        {
          "name": "punctuation.separator.arrow.precept",
          "match": "->"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.precept",
          "match": "==|!=|>=|<="
        },
        {
          "name": "keyword.operator.logical.precept",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.precept",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.precept",
          "match": ">|<"
        },
        {
          "name": "keyword.operator.assignment.precept",
          "match": "="
        }
      ]
    },
    "booleanNull": {
      "patterns": [
        {
          "name": "constant.language.precept",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.precept",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "identifierReference": {
      "patterns": [
        {
          "comment": "catch-all for bare identifier references in expression positions",
          "name": "variable.other.precept",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
