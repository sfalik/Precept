{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Precept",
  "scopeName": "source.precept",
  "patterns": [
    { "include": "#comment" },
    { "include": "#messageStrings" },
    { "include": "#strings" },
    { "include": "#machineDeclaration" },
    { "include": "#stateDeclaration" },
    { "include": "#eventWithArgsDeclaration" },
    { "include": "#eventDeclaration" },
    { "include": "#fieldCollectionDeclaration" },
    { "include": "#fieldScalarDeclaration" },
    { "include": "#ruleStatement" },
    { "include": "#ensureStatement" },
    { "include": "#fromOnHeader" },
    { "include": "#transitionTarget" },
    { "include": "#eventArgReference" },
    { "include": "#collectionMemberAccess" },
    { "include": "#stringMemberAccess" },
    { "include": "#rootEditDeclaration" },
    { "include": "#functionCall" },
    { "include": "#controlKeywords" },
    { "include": "#declarationKeywords" },
    { "include": "#grammarKeywords" },
    { "include": "#choiceType" },
    { "include": "#typeKeywords" },
    { "include": "#actionKeywords" },
    { "include": "#constraintKeywords" },
    { "include": "#outcomeKeywords" },
    { "include": "#arrowOperator" },
    { "include": "#operators" },
    { "include": "#booleanNull" },
    { "include": "#numbers" },
    { "include": "#identifierReference" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.precept",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.precept",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.precept",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "messageStrings": {
      "patterns": [
        {
          "name": "meta.message.because.precept",
          "match": "\\b(because)(\\s+)(\"(?:\\\\.|[^\"\\\\])*\")",
          "captures": {
            "1": { "name": "keyword.other.precept" },
            "3": { "name": "string.quoted.double.message.precept" }
          }
        },
        {
          "name": "meta.message.reject.precept",
          "match": "\\b(reject)(\\s+)(\"(?:\\\\.|[^\"\\\\])*\")",
          "captures": {
            "1": { "name": "keyword.other.precept" },
            "3": { "name": "string.quoted.double.message.precept" }
          }
        }
      ]
    },

    "machineDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.precept.precept",
          "match": "^(\\s*)(precept)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": { "name": "entity.name.type.precept.precept" }
          }
        }
      ]
    },
    "stateDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.state.precept",
          "match": "^(\\s*)(state)(\\s+)(.*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": {
              "patterns": [
                {
                  "name": "keyword.other.precept",
                  "match": "\\binitial\\b"
                },
                {
                  "name": "entity.name.type.state.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            }
          }
        }
      ]
    },
    "rootEditDeclaration": {
      "comment": "Root-level edit declaration (stateless precepts): edit all | edit Field1, Field2",
      "patterns": [
        {
          "name": "meta.declaration.edit.root.precept",
          "match": "^(\\s*)(edit)(\\s+)(all|(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*))",
          "captures": {
            "2": { "name": "keyword.other.precept" },
            "4": {
              "patterns": [
                {
                  "name": "keyword.other.precept",
                  "match": "\\ball\\b"
                },
                {
                  "name": "variable.other.field.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            }
          }
        }
      ]
    },
    "eventWithArgsDeclaration": {
      "comment": "event Name[, Name, ...] with Arg as type, Arg2 as type",
      "patterns": [
        {
          "name": "meta.declaration.event.precept",
          "match": "^(\\s*)(event)(\\s+)((?:[A-Za-z_][A-Za-z0-9_]*\\s*,\\s*)*[A-Za-z_][A-Za-z0-9_]*)(\\s+)(with)(\\s+)(.*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": {
              "patterns": [
                {
                  "name": "entity.name.function.event.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            },
            "6": { "name": "keyword.other.precept" },
            "8": {
              "patterns": [
                { "include": "#choiceType" },
                { "include": "#typeKeywords" },
                { "include": "#constraintKeywords" },
                { "include": "#declarationKeywords" },
                { "include": "#grammarKeywords" },
                { "include": "#numbers" },
                { "include": "#booleanNull" },
                { "include": "#operators" },
                {
                  "comment": "argument name before 'as'",
                  "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s+as\\b)",
                  "captures": {
                    "1": { "name": "variable.parameter.precept" }
                  }
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            }
          }
        }
      ]
    },
    "eventDeclaration": {
      "patterns": [
        {
          "name": "meta.declaration.event.precept",
          "match": "^(\\s*)(event)(\\s+)(.*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": {
              "patterns": [
                {
                  "name": "entity.name.function.event.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            }
          }
        }
      ]
    },
    "fieldCollectionDeclaration": {
      "comment": "field Name[, Name, ...] as set of string",
      "patterns": [
        {
          "name": "meta.field-declaration.collection.precept",
          "match": "^(\\s*)(field)(\\s+)((?:[A-Za-z_][A-Za-z0-9_]*\\s*,\\s*)*[A-Za-z_][A-Za-z0-9_]*)(\\s+)(as)(\\s+)(set|queue|stack)(\\s+)(of)(\\s+)(choice\\((?:\\s*\"(?:\\\\.|[^\"\\\\])*\"\\s*(?:,\\s*\"(?:\\\\.|[^\"\\\\])*\"\\s*)*)?\\)|string|number|boolean|integer|decimal)",
          "captures": {
            "2": { "name": "keyword.other.precept" },
            "4": {
              "patterns": [
                {
                  "name": "variable.other.field.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            },
            "6": { "name": "keyword.other.precept" },
            "8": { "name": "storage.type.precept" },
            "10": { "name": "keyword.other.precept" },
            "12": {
              "patterns": [
                {
                  "name": "storage.type.precept",
                  "match": "\\bchoice\\b"
                },
                {
                  "name": "punctuation.section.group.begin.precept",
                  "match": "\\("
                },
                {
                  "name": "punctuation.section.group.end.precept",
                  "match": "\\)"
                },
                { "include": "#strings" },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                },
                { "include": "#typeKeywords" }
              ]
            }
          }
        }
      ]
    },
    "fieldScalarDeclaration": {
      "comment": "field Name[, Name, ...] as string nullable default value — also handles computed fields: field Name as type -> expr",
      "patterns": [
        {
          "name": "meta.field-declaration.scalar.precept",
          "match": "^(\\s*)(field)(\\s+)((?:[A-Za-z_][A-Za-z0-9_]*\\s*,\\s*)*[A-Za-z_][A-Za-z0-9_]*)(\\s+)(as)(\\s+)(choice\\((?:\\s*\"(?:\\\\.|[^\"\\\\])*\"\\s*(?:,\\s*\"(?:\\\\.|[^\"\\\\])*\"\\s*)*)?\\)|string|number|boolean|integer|decimal)(.*)",
          "captures": {
            "2": { "name": "keyword.other.precept" },
            "4": {
              "patterns": [
                {
                  "name": "variable.other.field.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            },
            "6": { "name": "keyword.other.precept" },
            "8": {
              "patterns": [
                {
                  "name": "storage.type.precept",
                  "match": "\\bchoice\\b"
                },
                {
                  "name": "punctuation.section.group.begin.precept",
                  "match": "\\("
                },
                {
                  "name": "punctuation.section.group.end.precept",
                  "match": "\\)"
                },
                { "include": "#strings" },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                },
                { "include": "#typeKeywords" }
              ]
            },
            "9": {
              "patterns": [
                { "include": "#constraintKeywords" },
                { "include": "#declarationKeywords" },
                { "include": "#grammarKeywords" },
                { "include": "#controlKeywords" },
                { "include": "#arrowOperator" },
                { "include": "#functionCall" },
                { "include": "#collectionMemberAccess" },
                { "include": "#stringMemberAccess" },
                { "include": "#operators" },
                { "include": "#identifierReference" },
                { "include": "#booleanNull" },
                { "include": "#numbers" },
                { "include": "#strings" }
              ]
            }
          }
        }
      ]
    },
    "ruleStatement": {
      "comment": "rule Expr because \"Reason\"",
      "patterns": [
        {
          "name": "meta.rule.precept",
          "match": "^(\\s*)(rule)\\b",
          "captures": {
            "2": { "name": "keyword.other.precept" }
          }
        }
      ]
    },
    "ensureStatement": {
      "comment": "on EventName ensure ... OR in/to/from StateName[, ...] ensure ...",
      "patterns": [
        {
          "name": "meta.ensure.state.precept",
          "match": "^(\\s*)(in|to|from)(\\s+)(any|(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*))(\\s+)(ensure)\\b",
          "captures": {
            "2": { "name": "keyword.other.precept" },
            "4": {
              "patterns": [
                {
                  "name": "keyword.other.precept",
                  "match": "\\bany\\b"
                },
                {
                  "name": "entity.name.type.state.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            },
            "6": { "name": "keyword.other.precept" }
          }
        },
        {
          "name": "meta.ensure.precept",
          "match": "^(\\s*)(on)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s+)(ensure)\\b",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": { "name": "entity.name.function.event.precept" },
            "6": { "name": "keyword.other.precept" }
          }
        }
      ]
    },
    "fromOnHeader": {
      "patterns": [
        {
          "name": "meta.transition.header.precept",
          "match": "^(\\s*)(from)(\\s+)(any|[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)(\\s+)(on)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": { "name": "keyword.control.precept" },
            "4": {
              "patterns": [
                {
                  "name": "keyword.other.precept",
                  "match": "\\bany\\b"
                },
                {
                  "name": "entity.name.type.state.precept",
                  "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                  "name": "punctuation.separator.comma.precept",
                  "match": ","
                }
              ]
            },
            "6": { "name": "keyword.control.precept" },
            "8": { "name": "entity.name.function.event.precept" }
          }
        }
      ]
    },
    "transitionTarget": {
      "comment": "transition StateName — highlights the state name after transition keyword",
      "patterns": [
        {
          "name": "meta.transition.target.precept",
          "match": "\\b(transition)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.precept" },
            "3": { "name": "entity.name.type.state.precept" }
          }
        }
      ]
    },
    "eventArgReference": {
      "patterns": [
        {
          "name": "meta.event-arg-ref.precept",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.event.precept" },
            "2": { "name": "punctuation.accessor.precept" },
            "3": { "name": "variable.other.property.precept" }
          }
        }
      ]
    },
    "collectionMemberAccess": {
      "comment": "Dotted collection member accessors: .count, .min, .max, .peek.",
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)(count|min|max|peek)\\b",
          "captures": {
            "1": { "name": "variable.other.field.precept" },
            "2": { "name": "punctuation.accessor.precept" },
            "3": { "name": "variable.other.property.precept" }
          }
        }
      ]
    },
    "stringMemberAccess": {
      "comment": "Dotted string member accessors: .length (and future string accessors).",
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)(length)\\b",
          "captures": {
            "1": { "name": "variable.other.field.precept" },
            "2": { "name": "punctuation.accessor.precept" },
            "3": { "name": "variable.other.property.precept" }
          }
        }
      ]
    },

    "choiceType": {
      "comment": "choice(\"A\", \"B\") type syntax with explicit punctuation scopes.",
      "patterns": [
        {
          "name": "meta.type.choice.precept",
          "begin": "\\b(choice)(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.precept" },
            "2": { "name": "punctuation.section.group.begin.precept" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.section.group.end.precept" }
          },
          "patterns": [
            { "include": "#strings" },
            {
              "name": "punctuation.separator.comma.precept",
              "match": ","
            }
          ]
        }
      ]
    },

    "functionCall": {
      "comment": "Built-in function calls: function name followed by ( — must precede constraintKeywords so min(/max( match as functions, not constraints",
      "patterns": [
        {
          "match": "\\b(abs|floor|ceil|round|truncate|min|max|pow|sqrt|clamp|toLower|toUpper|startsWith|endsWith|trim|left|right|mid)(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.function.precept" }
          }
        }
      ]
    },

    "controlKeywords": {
      "patterns": [
        {
          "name": "keyword.control.precept",
          "match": "\\b(when|if|then|else)\\b"
        }
      ]
    },
    "declarationKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\b(precept|state|event|field|edit|from|on|in|to|as|nullable|default|because|initial|with|any|all|of|into)\\b"
        }
      ]
    },
    "grammarKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\b(rule|ensure)\\b"
        }
      ]
    },
    "typeKeywords": {
      "patterns": [
        {
          "name": "storage.type.precept",
          "match": "\\b(string|number|boolean|integer|decimal|choice|set|queue|stack)\\b"
        }
      ]
    },
    "actionKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\b(set|add|remove|enqueue|dequeue|push|pop|clear)\\b"
        }
      ]
    },
    "constraintKeywords": {
      "comment": "Field-level and event-arg-level constraint keywords (type-shape tier, issue #13)",
      "patterns": [
        {
          "name": "keyword.other.constraint.precept",
          "match": "\\b(nonnegative|positive|notempty|min|max|minlength|maxlength|mincount|maxcount|maxplaces|ordered)\\b"
        }
      ]
    },
    "outcomeKeywords": {
      "patterns": [
        {
          "name": "keyword.other.precept",
          "match": "\\bno\\s+transition\\b"
        },
        {
          "name": "keyword.other.precept",
          "match": "\\b(transition|reject)\\b"
        }
      ]
    },
    "arrowOperator": {
      "patterns": [
        {
          "name": "punctuation.separator.arrow.precept",
          "match": "->"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.precept",
          "match": "\\b(and|or|not|contains)\\b"
        },
        {
          "name": "keyword.operator.comparison.precept",
          "match": "==|!=|>=|<="
        },
        {
          "name": "keyword.operator.arithmetic.precept",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.precept",
          "match": ">|<"
        },
        {
          "name": "keyword.operator.assignment.precept",
          "match": "="
        }
      ]
    },
    "booleanNull": {
      "patterns": [
        {
          "name": "constant.language.precept",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.precept",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "identifierReference": {
      "patterns": [
        {
          "comment": "catch-all for bare identifier references in expression positions",
          "name": "variable.other.precept",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
