# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/

# Visual Studio 2015 cache/options directory
.vs/

# VS Code - ignore user settings but keep shared configs
.vscode/*
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/mcp.json

# Temporary and local scratch files
temp/
src/Precept/temp/
tools/Precept.LanguageServer/temp/

# VS Code extension generated files
tools/Precept.VsCode/node_modules/
tools/Precept.VsCode/out/
tools/Precept.VsCode/*.vsix
tools/Precept.VsCode/.vscode-test/
tools/Precept.VsCode/mcp-server/
tools/Precept.VsCode/server/

# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
